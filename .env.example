# --- LLM: Ollama (default, testo + tool in locale) ---
# Installa Ollama da https://ollama.com poi:
#   ollama pull qwen2.5:7b
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_NUM_CTX=8192

# --- LLM: Groq (cloud, veloce) ---
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Opzionale: tolleranza a rate limit (429 + Retry-After); default 8 retry, 300s timeout richiesta
# GROQ_MAX_RETRIES=8
# GROQ_REQUEST_TIMEOUT_SECONDS=300

# DB per settore: vendita:6433, acquisto:6434, manutenzione:6435
VENDITA_DATABASE_URL=postgresql://team:team@localhost:6433/tickets
ACQUISTO_DATABASE_URL=postgresql://team:team@localhost:6434/tickets
MANUTENZIONE_DATABASE_URL=postgresql://team:team@localhost:6435/tickets
# Registry pratiche (coda + richiedente + timestamp): pratiche:6436
PRATICHE_DATABASE_URL=postgresql://team:team@localhost:6436/pratiche
# Opzionale: protezione API (header X-API-Key o Authorization: Bearer). La UI su /ui resta senza chiave.
# HELPER_API_KEY=genera-un-valore-lungo-casuale
# Diagnostica intake: JSON `debug` nella risposta + log riga «intake_debug»
# DEBUG_INTAKE=1
# Se il modello non chiude con il tool, apri comunque pratica (euristica contatti + dati operativi: km+anno veicolo o qty ricambi)
# INTAKE_FALLBACK_OPEN=1
