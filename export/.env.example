# LLM
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_NUM_CTX=8192

# LLM cloud (optional)
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MAX_RETRIES=8
# GROQ_REQUEST_TIMEOUT_SECONDS=300

# Ticket backend: stub | zammad
TICKETING_BACKEND=stub

# Generic ticket policy (comma-separated)
REQUIRED_FIELDS=name,email,subject,description

# Zammad integration
ZAMMAD_BASE_URL=http://127.0.0.1:8080
ZAMMAD_API_TOKEN=
ZAMMAD_CUSTOMER=customer@example.com
ZAMMAD_GROUP=Users
